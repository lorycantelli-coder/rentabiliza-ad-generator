# ═══════════════════════════════════════════════════════════════════
# Rentabiliza Ad Copy Generator — Environment Variables
# ═══════════════════════════════════════════════════════════════════

# REQUIRED: Claude AI API Key
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-YOUR_KEY_HERE

# Node.js Environment
# Options: development, production, staging
NODE_ENV=development

# Logging Level
# Options: error, warn, info, debug
LOG_LEVEL=info

# Server Port
PORT=5000

# Frontend Port (for docker-compose)
FRONTEND_PORT=8888

# ═══════════════════════════════════════════════════════════════════
# Optional: Google Gemini API (for future features)
# ═══════════════════════════════════════════════════════════════════
# VITE_GEMINI_API_KEY=YOUR_GEMINI_KEY_HERE

# ═══════════════════════════════════════════════════════════════════
# Instructions:
# ═══════════════════════════════════════════════════════════════════
# 1. Copy this file: cp .env.example .env
# 2. Fill in your ANTHROPIC_API_KEY
# 3. Run backend: npm run backend
# 4. Open frontend: http://localhost:8888/app.html
#
# For Docker:
# docker-compose up -d
# ═══════════════════════════════════════════════════════════════════
